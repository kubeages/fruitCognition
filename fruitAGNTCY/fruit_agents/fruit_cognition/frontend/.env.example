# =============================================================================
# FruitCognition frontend (Vite) — copy this file to `.env` in this directory:
#   cp .env.example .env
#
# Why `.env` here (not `.env.local`)?
# -----------------------------------------------------------------------------
# - **One obvious name:** `.env` is the usual file developers expect for app
#   config; Vite loads it automatically for `npm run dev` / `npm run build`.
# - **Separate from backend:** `fruit_cognition/.env` is for Docker Compose and Python
#   agents (LLM keys, profiles, etc.). Keeping `frontend/.env` avoids mixing
#   Vite `VITE_*` keys with backend-only variables.
# - **Git-safe:** The repository `.gitignore` ignores `.env`, so your local
#   `frontend/.env` is never committed. This `.env.example` stays committed as
#   the documented template.
# - **Docker UI:** `docker compose --profile frontend up --build` (from fruit_cognition/)
#   uses **only** this file
#   (`frontend/.env`) for `VITE_*` — same as `npm run dev`. No duplicate vars in
#   `fruit_cognition/.env`.
# =============================================================================

VITE_EXCHANGE_APP_API_URL=http://127.0.0.1:8000
VITE_LOGISTICS_APP_API_URL=http://127.0.0.1:9090
VITE_GRAFANA_URL=http://127.0.0.1:3001
VITE_DISCOVERY_APP_API_URL=http://127.0.0.1:8882
VITE_AGENTIC_WORKFLOWS_API_URL=http://127.0.0.1:9105
VITE_DIRECTORY_VERSION=v1.0.0
VITE_DIRECTORY_SERVER_URL=http://127.0.0.1:8888
