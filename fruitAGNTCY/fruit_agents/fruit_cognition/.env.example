PYTHONPATH=.

# =============================
# Docker Compose Settings
# =============================

# Set the COMPOSE_PROFILES variable to specify which services to run with Docker Compose.
# Include "observability" to start the observability stack (otel-collector, clickhouse, grafana, mce-api-layer, metrics-computation-engine); omit it to run without that stack.
COMPOSE_PROFILES=farms,logistics,recruiter,observability,frontend

#============================
# LLM Provider Settings
#============================
# FruitAGNTCY uses litellm to manage LLM connections.
# Full list of supported providers:https://docs.litellm.ai/docs/providers
# Note: In FruitAGNTCY, the environment variable for specifying the model is always LLM_MODEL, regardless of the provider.
# Examples:

# OpenAI
# LLM_MODEL="openai/<model_of_choice>"
# OPENAI_API_KEY=<your_openai_api_key>

# Azure OpenAI
# LLM_MODEL="azure/<your_deployment_name>"
# AZURE_API_BASE=https://your-azure-resource.openai.azure.com/
# AZURE_API_KEY=<your_azure_api_key>
# AZURE_API_VERSION=<your_azure_api_version>

# GROQ
# LLM_MODEL="groq/<model_of_choice>"
# GROQ_API_KEY=<your_groq_api_key>

# Litellm Proxy
# LLM_MODEL="azure/<your_deployment_name>"
# LITELLM_PROXY_BASE_URL=<your_litellm_proxy_base_url>
# LITELLM_PROXY_API_KEY=<your_litellm_proxy_api_key>

# NVIDIA NIM
# LLM_MODEL="nvidia_nim/<model_of_choice>"
# NVIDIA_NIM_API_KEY=<your_nvidia_api_key>
# NVIDIA_NIM_API_BASE=<your_nvidia_nim_endpoint_url>

# Recommended temperature setting for OpenAI models
OPENAI_TEMPERATURE=0.7

# When true, agents fail at startup if the configured LLM does not support streaming (based on LiteLLM metadata).
ENSURE_STREAMING_LLM=false

# === Agntcy TBAC Settings (Docker Compose) ===
# Set these variables to enable Agntcy Identity Auth (TBAC).
IDENTITY_AUTH_ENABLED="false"
# For local development, each service uses its own API key variable.
# In production, each service uses IDENTITY_SERVICE_API_KEY within its environment.
IDENTITY_SERVICE_API_KEY_AUCTION_SUPERVISOR=""
IDENTITY_SERVICE_API_KEY_PAYMENT_MCP=""
IDENTITY_SERVICE_API_KEY_VIETNAM_FARM=""
IDENTITY_SERVICE_API_KEY_COLOMBIA_FARM=""

#============================
# Local Development Settings
#============================
#(not needed when running Docker Compose)

# Observability (use together with the observability profile in COMPOSE_PROFILES).
# OTEL_SDK_DISABLED: common var used by 3rd-party libraries built on OpenTelemetry (OTEL). When true, tracing is disabled and no telemetry is exported; when false or unset, tracing is enabled (use the observability profile if you want telemetry collected).
OTEL_SDK_DISABLED=false
# OTLP_HTTP_ENDPOINT is only used when OTEL_SDK_DISABLED is not true.
# OTLP_HTTP_ENDPOINT="http://localhost:4318"

# === Transport Settings ===

DEFAULT_MESSAGE_TRANSPORT=SLIM

# To swap to NATS, set DEFAULT_MESSAGE_TRANSPORT=NATS and ensure the NATS server is running locally.
# DEFAULT_MESSAGE_TRANSPORT=NATS

SLIM_SERVER="localhost:46357"

NATS_SERVER="localhost:4222"

SLIM_SHARED_SECRET="slim-shared-secret-REPLACE_WITH_RANDOM_32PLUS_CHARS"


# === Agntcy TBAC Settings (Local) ===
# set the variable IDENTITY_SERVICE_API_KEY in different terminals for each service.

# Enables dynamic reload of the backend (uvicorn) without process restart.
# Set to false or leave unset if you don't need automatic reload and want faster startup/response. In production, set to false or leave unset.
HOT_RELOAD_MODE=true

# FruitCognition UI (`docker compose --profile frontend up --build` from fruit_cognition/): **`VITE_*` live only in
# `frontend/.env`** — copy from `frontend/.env.example`. Do not duplicate here.

# === APIs (CORS) ===
# Comma-separated browser origins allowed to call FruitCognition HTTP APIs with credentials (scheme + host + port).
# Applies to services that serve the UI: auction (exchange) supervisor, logistics agents and supervisor,
# recruiter supervisor, agentic workflows API, etc. Use the origin shown in the address bar for your UI,
# not the API base URL. When unset or empty, defaults are http://localhost:3000 and http://127.0.0.1:3000.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

