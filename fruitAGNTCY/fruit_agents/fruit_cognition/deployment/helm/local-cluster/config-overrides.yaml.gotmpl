{{- /*
  Applies the same config overrides to multiple subcharts.
  Include all dependency names (or aliases) from your local-cluster Chart.yaml.
*/ -}}

{{- $auctionTargets := list "brazil-farm" "colombia-farm" "vietnam-farm" -}}
{{- $logisticsTargets := list "logistics-farm" "logistics-accountant" "logistics-shipper" "logistics-helpdesk" -}}

{{- $shared := dict "config" (dict
  "azureApiBase" (env "AZURE_API_BASE")
  "azureApiVersion" (env "AZURE_API_VERSION")
  "llmModel" (env "LLM_MODEL")
  "otlpHttpEndpoint" "http://fruit-cognition-local-cluster-opentelemetry-collector:4318"
  "identityApiServerUrl" "https://api.agent-identity.outshift.com"
) -}}

{{- $slim := dict "config" (dict
  "transportServerEndpoint" "http://fruit-cognition-local-cluster-slim:46357"
  "defaultMessageTransport" "SLIM"
  "slimServer" "fruit-cognition-local-cluster-slim:46357"
  "natsServer" "fruit-cognition-local-cluster-nats:4222"
) -}}

{{- $nats := dict "config" (dict
  "transportServerEndpoint" "nats://fruit-cognition-local-cluster-nats:4222"
  "defaultMessageTransport" "NATS"
  "slimServer" "fruit-cognition-local-cluster-slim:46357"
  "natsServer" "fruit-cognition-local-cluster-nats:4222"
) -}}

{{- /* Auction targets: merge shared + NATS into one config block */ -}}
{{- range $name := $auctionTargets }}
{{- $cfg := merge (deepCopy $shared.config) (deepCopy $nats.config) }}
{{ $name }}:
  config:
{{- toYaml $cfg | nindent 4 }}
  externalSecrets:
    secretStoreName: local-secret-store
    secretStoreKind: ClusterSecretStore
    data:
      - secretKey: AZURE_API_KEY
        remoteRef:
          key: my-local-secret
          property: AZURE_API_KEY
      - secretKey: SLIM_SHARED_SECRET
        remoteRef:
          key: my-local-secret
          property: SLIM_SHARED_SECRET
{{- end }}

{{- /* Logistics targets: merge shared + SLIM into one config block */ -}}
{{- range $name := $logisticsTargets }}
{{- $cfg := merge (deepCopy $shared.config) (deepCopy $slim.config) }}
{{ $name }}:
  config:
{{- toYaml $cfg | nindent 4 }}
  externalSecrets:
    secretStoreName: local-secret-store
    secretStoreKind: ClusterSecretStore
    data:
      - secretKey: AZURE_API_KEY
        remoteRef:
          key: my-local-secret
          property: AZURE_API_KEY
      - secretKey: SLIM_SHARED_SECRET
        remoteRef:
          key: my-local-secret
          property: SLIM_SHARED_SECRET
{{- end }}

# Explicit per-chart overrides with ingress enabled
auction-supervisor:
  environment: local
  config:
{{- toYaml (merge (deepCopy $shared.config) (deepCopy $nats.config)) | nindent 4 }}
  externalSecrets:
    secretStoreName: local-secret-store
    secretStoreKind: ClusterSecretStore
    data:
      - secretKey: AZURE_API_KEY
        remoteRef:
          key: my-local-secret
          property: AZURE_API_KEY
      - secretKey: SLIM_SHARED_SECRET
        remoteRef:
          key: my-local-secret
          property: SLIM_SHARED_SECRET

logistics-supervisor:
  environment: local
  config:
{{- toYaml (merge (deepCopy $shared.config) (deepCopy $slim.config)) | nindent 4 }}
  externalSecrets:
    secretStoreName: local-secret-store
    secretStoreKind: ClusterSecretStore
    data:
      - secretKey: AZURE_API_KEY
        remoteRef:
          key: my-local-secret
          property: AZURE_API_KEY
      - secretKey: SLIM_SHARED_SECRET
        remoteRef:
          key: my-local-secret
          property: SLIM_SHARED_SECRET

recruiter:
  config:
{{- $recruiterCfg := merge (deepCopy $shared.config) (deepCopy $nats.config) }}
{{- toYaml $recruiterCfg | nindent 4 }}
    enableHttp: "true"
    mcpConnectionMode: "binary"
    directoryClientServerAddress: ""
    directoryClientTlsSkipVerify: "true"
    oasfApiValidationSchemaUrl: "https://schema.oasf.outshift.com"
  externalSecrets:
    secretStoreName: local-secret-store
    secretStoreKind: ClusterSecretStore
    data:
      - secretKey: AZURE_API_KEY
        remoteRef:
          key: my-local-secret
          property: AZURE_API_KEY
      - secretKey: SLIM_SHARED_SECRET
        remoteRef:
          key: my-local-secret
          property: SLIM_SHARED_SECRET

agentic-workflows-api:
  environment: local

recruiter-supervisor:
  environment: local
  config:
{{- toYaml (merge (deepCopy $shared.config) (deepCopy $nats.config)) | nindent 4 }}
    recruiterAgentUrl: "http://recruiter:8881"
  externalSecrets:
    secretStoreName: local-secret-store
    secretStoreKind: ClusterSecretStore
    data:
      - secretKey: AZURE_API_KEY
        remoteRef:
          key: my-local-secret
          property: AZURE_API_KEY
      - secretKey: SLIM_SHARED_SECRET
        remoteRef:
          key: my-local-secret
          property: SLIM_SHARED_SECRET

localExternalSecret:
  azureApiKey: {{ env "AZURE_API_KEY" | quote }}
  slimSharedSecret: {{ env "SLIM_SHARED_SECRET" | default "dummy_password" | quote }}

